st one food item.\n        case when coalesce(ois.count_food_items, 0) > 0 then true else false end  as is_food_order,\n        case when coalesce(ois.count_drink_items, 0) > 0 then true else false end as is_drink_order\n\n    from orders o\n    left join order_items_summary ois on ois.order_id = o.order_id\n\n)\n\nselect * from final", "relation_name": "DEV.datafold_tmp.orders_caab7724", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-05-20T19:51:33.252540Z", "completed_at": "2026-05-20T19:51:33.259270Z"}, {"name": "execute", "started_at": "2026-05-20T19:51:33.259443Z", "completed_at": "2026-05-20T19:51:33.697351Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.4451899528503418, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c48047-060b-fd08-0008-fb83437caece"}, "message": null, "failures": 0, "unique_id": "test.jaffle_shop.not_null_orders_order_id.cf6c17daed", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect order_id\nfrom DEV.datafold_tmp.orders_caab7724\nwhere order_id is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-05-20T19:51:33.699727Z", "completed_at": "2026-05-20T19:51:33.703733Z"}, {"name": "execute", "started_at": "2026-05-20T19:51:33.703925Z", "completed_at": "2026-05-20T19:51:34.159298Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.4603266716003418, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c48047-060b-fd0a-0008-fb83437ccdf6"}, "message": null, "failures": 0, "unique_id": "test.jaffle_shop.unique_orders_order_id.fed79b3a6e", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    order_id as unique_field,\n    count(*) as n_records\n\nfrom DEV.datafold_tmp.orders_caab7724\nwhere order_id is not null\ngroup by order_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "ba