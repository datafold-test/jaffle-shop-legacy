d_at": "2026-05-20T20:08:17.833823Z", "completed_at": "2026-05-20T20:08:18.892682Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 1.0651490688323975, "adapter_response": {"_message": "SUCCESS 8", "code": "SUCCESS", "rows_affected": 8, "query_id": "01c48058-060b-fd08-0008-fb83437cf14a", "rows_inserted": 8, "rows_deleted": 0, "rows_updated": 0, "rows_duplicates": 0}, "message": "SUCCESS 8", "failures": null, "unique_id": "model.jaffle_shop.orders", "compiled": true, "compiled_code": "\n\nwith order_items_summary as (\n\n    select\n        order_id,\n        sum(supply_cost)                                      as order_cost,\n        sum(product_price)                                    as order_items_subtotal,\n        count(order_item_id)                                  as count_order_items,\n        sum(case when is_food_item  then 1 else 0 end)        as count_food_items,\n        sum(case when is_drink_item then 1 else 0 end)        as count_drink_items\n\n    from DEV.DATAFOLD_TMP.order_items_2e88025c_upstream\n\n    group by order_id\n\n),\n\nstg_orders as (\n\n    select * from DEV.DATAFOLD_TMP.stg_orders_2e88025c_upstream\n\n),\n\nfinal as (\n\n    select\n        o.order_id,\n        o.location_id,\n        o.customer_id,\n        o.ordered_at,\n        o.subtotal,\n        o.tax_paid,\n        o.order_total,\n        ois.order_cost,\n        ois.order_items_subtotal,\n        ois.count_order_items,\n        ois.count_food_items,\n        ois.count_drink_items,\n        case when coalesce(ois.count_food_items, 0) > 0 then true else false end  as is_food_order,\n        case when coalesce(ois.count_drink_items, 0) > 0 then true else false end as is_drink_order\n\n    from stg_orders o\n    left join order_items_summary ois on ois.order_id = o.order_id\n\n)\n\nselect * from final", "relation_name": "DEV.DATAFOLD_TMP.orders_2e88025c_upstream", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-05-20T20:08:18