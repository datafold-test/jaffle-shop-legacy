ers_order_id.fed79b3a6e", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    order_id as unique_field,\n    count(*) as n_records\n\nfrom DEV.DATAFOLD_TMP.orders_2e88025c_upstream\nwhere order_id is not null\ngroup by order_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-05-20T20:08:20.188806Z", "completed_at": "2026-05-20T20:08:20.193343Z"}, {"name": "execute", "started_at": "2026-05-20T20:08:20.193704Z", "completed_at": "2026-05-20T20:08:21.120163Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.9321310520172119, "adapter_response": {"_message": "SUCCESS 8", "code": "SUCCESS", "rows_affected": 8, "query_id": "01c48058-060b-fd0a-0008-fb83437d00ae", "rows_inserted": 8, "rows_deleted": 0, "rows_updated": 0, "rows_duplicates": 0}, "message": "SUCCESS 8", "failures": null, "unique_id": "model.jaffle_shop.customers", "compiled": true, "compiled_code": "\n\nwith customer_orders_summary as (\n\n    select\n        customer_id,\n        count(distinct order_id)                                                  as count_lifetime_orders,\n        case when count(distinct order_id) > 1 then true else false end           as is_repeat_buyer,\n        min(ordered_at)                                                           as first_ordered_at,\n        max(ordered_at)                                                           as last_ordered_at,\n        sum(subtotal)                                                             as lifetime_spend_pretax,\n        sum(tax_paid)                                                             as lifetime_tax_paid,\n        sum(order_total)                                                          as lifetime_spend\n\n    from DEV.DATAFOLD_TMP.orders_2e88025c_upstream\n\n    group by customer_id\n\n),\n\ncustomers as (\n\n    select * from DEV.DATAFOLD_TMP.stg_customers_2e88025c_upstream\n\n),\n\nfinal as (\n\n    select\n        c.customer_id,\n        c.customer_name,\n        coalesce(cos.count_lifetime_orders, 0)   as count_lifetime_orders,\n        coalesce(cos.is_repeat_buyer, false)      as is_repeat_buyer,\n        cos.first_ordered_at,\n        cos.last_ordered_at,\n        coalesce(cos.lifetime_spend_pretax, 0)   as lifetime_spend_pretax,\n        coalesce(cos.lifetime_tax_paid, 0)       as lifetime_tax_paid,\n        coalesce(cos.lifetime_spend, 0)          as lifetime_spend\n\n    from customers c\n    left join customer_orders_summary cos on cos.customer_id = c.customer_id\n\n)\n\nselect * from final", "relation_name": "DEV.DATAFOLD_TMP.customers_2e88025c", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-05-20T20:08:21.124138Z", "completed_at": "2026-05-20T20:08:21.129778Z"}, {"name": "execute", "started_at": "2026-05-20T20:08:21.130148Z", "completed_at": "2026-05-20T20:08:21.425880Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.30251502990722656, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c48058-060b-fd08-0008-fb83437cf16a"}, "message": null, "failures": 0, "unique_id": "test.jaffle_shop.not_null_customers_customer_id.5c9bf9911d", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect customer_id\nfrom DEV.DATAFOLD_TMP.customers_2e88025c\nwhere customer_id is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-05-20T20:08:21.428446Z", "completed_at": "2026-05-20T20:08:21.433925Z"}, {"name": "execute", "started_at": "2026-05-20T20:08:21.434554Z", "completed_at": "2026-05-20T20:08:21.796696Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.36895108222961426, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c48058-060b-fd0a-0008-fb83437d00b6"}, "message": null, "failures": 0, "unique_id": "test.jaffle_shop.uni